CREATE DATABASE voting_db;
USE voting_db;

CREATE TABLE users (
    username VARCHAR(50) PRIMARY KEY,
    password VARCHAR(50),
    voted BOOLEAN DEFAULT FALSE
);

CREATE TABLE votes (
    party VARCHAR(20) PRIMARY KEY,
    count INT DEFAULT 0
);

